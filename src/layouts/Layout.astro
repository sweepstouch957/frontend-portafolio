---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Allan Aceituno · Fullstack Developer",
  description = "Fullstack developer with 5+ years building Next.js apps, Node.js backends, WhatsApp/SMS automations, loyalty systems and design systems. Open to work — remote.",
} = Astro.props;

const canonical = "https://portafolio-delta.vercel.app";
const ogImage = `${canonical}/og.png`;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="fullstack developer, Next.js, Node.js, React, TypeScript, MongoDB, WhatsApp bots, SMS automation, loyalty systems, Honduras, remote"
    />
    <meta name="author" content="Allan Aceituno" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0d1117" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Allan Aceituno" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@allanaceituno" />
    <meta name="twitter:creator" content="@allanaceituno" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- JSON-LD Structured Data -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Allan Aceituno",
        jobTitle: "Fullstack Developer",
        url: canonical,
        email: "allan.aceituno20@gmail.com",
        sameAs: [
          "https://github.com/allan021",
          "https://www.linkedin.com/in/allan-castro-1055b4150/",
          "https://codepen.io/Allan-Aceituno",
        ],
        knowsAbout: [
          "Next.js",
          "Node.js",
          "React",
          "TypeScript",
          "MongoDB",
          "Redis",
          "WhatsApp API",
          "Infobip",
          "AWS",
          "Azure",
          "Flutter",
          "Kotlin",
          "Prisma",
          "Sanity",
        ],
        worksFor: { "@type": "Organization", name: "Sweepstouch" },
      })}
    />

    <!-- LCP image preload -->
    <link rel="preload" as="image" href="/allan.webp" fetchpriority="high" />

    <!-- Fonts — non-blocking (preload → swap to stylesheet after parse) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,700&family=Geist:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,700&family=Geist:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Skip to main -->
    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 8px;
        z-index: 9999;
        padding: 8px 16px;
        background: var(--accent, #b9ff66);
        color: #0a0d14;
        font-weight: 600;
        border-radius: 8px;
        text-decoration: none;
        font-size: 14px;
      }
      .skip-link:focus {
        left: 8px;
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
  </body>
</html>
